# Application URL (used for metadata, sitemap, and OG tags)
# NEXT_PUBLIC_SITE_URL=https://ra2plabs.com

# Contact email (displayed in CTA and footer)
# NEXT_PUBLIC_CONTACT_EMAIL=ceo@ra2plabs.com

# WhatsApp number (displayed in CTA section)
# Format: country code + number without symbols
# NEXT_PUBLIC_WHATSAPP_NUMBER=68345701

# ─── Contact Form - Spam Protection (Cloudflare Turnstile) ──
# Get your keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Use "1x00000000000000000000AA" as site key and
# "1x0000000000000000000000000000000AA" as secret key for local dev.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAA...

# ─── Contact Form - Email (SMTP / Google Workspace) ─────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=tu-correo@ra2plabs.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx (App Password de Google)
# NEXT_PUBLIC_CONTACT_EMAIL=ceo@ra2plabs.com

# ─── Meeting Scheduling - Calendly ───────────────────────
# Set your Calendly event link to enable the "Agendar Reunión" button.
# When unset, the button shows "Próximamente" as a placeholder.
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/ra2plabs/consultoria

# ─── Nexus AI Assistant - OpenAI Integration ───────────
# When set, Nexus uses OpenAI instead of keyword matching.
# When unset, Nexus works in offline mode with mock responses.
# OPENAI_API_KEY=sk-proj-...

# ─── Analytics ────────────────────────────────────────────
# Comma-separated list of providers to enable.
# Supported: plausible | umami | google
# NEXT_PUBLIC_ANALYTICS_PROVIDER=plausible
#
# Plausible: custom script src (optional, defaults to plausible.io)
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
#
# Umami: custom script src + website ID
# NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Google Analytics: measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PWA / Push Notifications
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
